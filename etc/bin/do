#!/usr/bin/env python3

import argparse
import os
import shutil
import subprocess
import sys
import tarfile
import tomllib
import urllib.request
from pathlib import Path


os.system("clear")

# ----------------------------------------------------------------------
# Cargo‑style log helpers
# ----------------------------------------------------------------------
GREEN   = "\033[32;1m"
BLUE    = "\033[34;1m"
YELLOW  = "\033[33;1m"
RED     = "\033[31;1m"
BOLD    = "\033[1m"
NC      = "\033[0m"

SEP     = shutil.get_terminal_size((80, 20)).columns

def status(action: str, target: str):
    """Cargo-like progress line."""
    print(f"   {GREEN}{action}{NC} {target}")

def finished(target: str):
    """Cargo-like finished line."""
    print(f"    {GREEN}Finished{NC} {target}")

def warn(msg: str):
    """Print a warning."""
    print(f"{YELLOW}{BOLD}warning{NC}{BOLD}:{NC} {msg}")

def error(msg: str, exit_code: int = 1):
    """Print an error and exit."""
    print(f"{RED}{BOLD}error{NC}{BOLD}:{NC} {msg}", file=sys.stderr)
    sys.exit(exit_code)


# ----------------------------------------------------------------------
# Paths & constants
# ----------------------------------------------------------------------
PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent  # kernel/
TARGET       = PROJECT_ROOT / "target"
PROFILES_DIR = PROJECT_ROOT / "etc" / "profiles"
PROFILE_FILE = TARGET / "current_profile"
KERNEL_NAME  = "kernel"
LIMINE_VERSION = "12.3.2"
LIMINE_URL   = f"https://github.com/limine-bootloader/limine/releases/download/v{LIMINE_VERSION}/limine-binary.tar.gz"


# ----------------------------------------------------------------------
# Tool validation
# ----------------------------------------------------------------------
def check_tools():
    """Verify that all required external commands are available."""
    required = {
        "cargo":                   "Rust build tool",
        "xorriso":                 "ISO creation",
        "qemu-system-x86_64":      "QEMU x86_64 emulator",
        "make":                    "build Limine",
    }
    missing = []
    for cmd, desc in required.items():
        if shutil.which(cmd) is None:
            missing.append(f"{cmd} ({desc})")
    if missing:
        error("Missing required tools: " + ", ".join(missing) + ".\nPlease install them and try again.")


# ----------------------------------------------------------------------
# Utility
# ----------------------------------------------------------------------
def run(cmd: list[str], **kwargs):
    """Thin wrapper around subprocess.run(..., check=True)."""
    try:
        subprocess.run(cmd, check=True, **kwargs)
    except subprocess.CalledProcessError as e:
        error(f"Command failed with exit code {e.returncode}: {' '.join(cmd)}")


def is_up_to_date(target: Path, *sources: Path) -> bool:
    """
    Return True if `target` exists and its mtime is >= mtime of every source.
    If any source is missing, return False (trigger a rebuild).
    """
    if not target.exists():
        return False
    target_mtime = os.path.getmtime(target)
    for src in sources:
        if not src.exists():
            return False
        if os.path.getmtime(src) > target_mtime:
            return False
    return True


# ----------------------------------------------------------------------
# Profile management
# ----------------------------------------------------------------------
def load_profiles() -> dict[str, dict]:
    """Load all profile definitions from etc/profiles/*.toml."""
    if not PROFILES_DIR.is_dir():
        error(
            f"Project filesystem corrupted: {PROFILES_DIR} does not exist or is not a directory.\n"
            "Clone the repository again and try again."
        )

    profiles = {}
    for entry in PROFILES_DIR.iterdir():
        if entry.suffix != ".toml":
            continue
        name = entry.stem
        with entry.open("rb") as fh:
            profiles[name] = tomllib.load(fh)

    if not profiles:
        error(
            f"No profile files found in {PROFILES_DIR}.\n"
            "The project filesystem appears corrupted. Clone again."
        )
    return profiles


def read_current_profile() -> str:
    """Return the currently selected profile name."""
    try:
        return PROFILE_FILE.read_text().strip()
    except FileNotFoundError:
        return ""


def write_current_profile(profile: str):
    """Persist the selected profile name."""
    TARGET.mkdir(exist_ok=True)
    PROFILE_FILE.write_text(profile + "\n")


def generate_cargo_toml(profile_name: str):
    """
    Create Cargo.toml from the template etc/Cargo.in,
    replacing {KERNEL_NAME} and {profile_name}.
    """
    template_path = PROJECT_ROOT / "etc" / "Cargo.in"
    target_path   = PROJECT_ROOT / "Cargo.toml"

    if not template_path.is_file():
        error(f"Template file missing: {template_path}")

    template = template_path.read_text()
    rendered = template.replace("{KERNEL_NAME}", KERNEL_NAME)
    rendered = rendered.replace("{profile_name}", profile_name)
    rendered = rendered.replace("{{", "{").replace("}}", "}")

    target_path.write_text(rendered)


def ensure_cargo_toml():
    """Regenerate Cargo.toml if it's older than the template."""
    profile_name = read_current_profile()
    if not profile_name:
        error("No profile selected. Run 'do config [PROFILE]' first.")

    cargo_toml = PROJECT_ROOT / "Cargo.toml"
    cargo_in   = PROJECT_ROOT / "etc" / "Cargo.in"

    if not cargo_toml.exists() or os.path.getmtime(cargo_toml) < os.path.getmtime(cargo_in):
        status("Updating", "Cargo.toml from template")
        generate_cargo_toml(profile_name)


# ----------------------------------------------------------------------
# Limine fetching & building (with version tracking)
# ----------------------------------------------------------------------
def limine_dir() -> Path:
    """Root of the extracted Limine source."""
    return TARGET / "limine" / "limine-binary"


def limine_binary(name: str) -> Path:
    """Path to a built Limine executable / binary."""
    return limine_dir() / name


def limine_version_file() -> Path:
    """Path to the file storing the fetched Limine version."""
    return TARGET / "limine" / ".version"


def prepare_limine():
    """
    Ensure Limine is fetched, extracted, and built.
    Only refetches if the version has changed.
    """
    version_file = limine_version_file()
    if limine_dir().is_dir() and version_file.exists():
        if version_file.read_text().strip() == LIMINE_VERSION:
            return

    # If we reach here, we need to (re-)fetch Limine
    if limine_dir().exists():
        shutil.rmtree(limine_dir().parent)   # remove target/limine entirely

    # Download
    status("Fetching", f"limine v{LIMINE_VERSION}")
    archive = TARGET / "limine.tgz"
    TARGET.mkdir(exist_ok=True)

    try:
        with urllib.request.urlopen(LIMINE_URL) as response, open(archive, "wb") as fh:
            shutil.copyfileobj(response, fh)
    except Exception as exc:
        error(f"Failed to download Limine: {exc}")

    # Extract
    with tarfile.open(archive, "r:gz") as tar:
        tar.extractall(path=TARGET / "limine")

    # Build
    status("Compiling", "limine")
    run(
        ["make", "-C", str(limine_dir()), "--no-print-directory", "-s"],
        cwd=limine_dir(),
    )
    # Persist the version we just built
    version_file.parent.mkdir(parents=True, exist_ok=True)
    version_file.write_text(LIMINE_VERSION + "\n")
    finished(f"limine v{LIMINE_VERSION}")


# ----------------------------------------------------------------------
# Build steps
# ----------------------------------------------------------------------
def build_kernel(profile: dict):
    """Run `cargo build` with the selected profile and features."""
    cargo_opts = profile["cargo"]
    env = os.environ.copy()
    env.update(profile.get("env", {}))

    cmd = [
        "cargo", "build",
        "--profile", cargo_opts["profile"],
    ]

    features = cargo_opts.get("features")
    if features:
        cmd.extend(["--features", ",".join(features)])

    run(cmd, env=env)


def setup_iso(profile_name: str):
    """Populate the ISO root filesystem with kernel and bootloader files."""
    iso_root = TARGET / "x86_64-unknown-none" / profile_name / "iso-root"
    kernel_bin = TARGET / "x86_64-unknown-none" / (profile_name if profile_name != "dev" else "debug" )/ KERNEL_NAME

    if not kernel_bin.is_file():
        error(f"Kernel binary not found: {kernel_bin}")

    status("Preparing", "ISO filesystem")
    boot_dir = iso_root / "boot" / "limine"
    efi_dir  = iso_root / "EFI" / "BOOT"
    boot_dir.mkdir(parents=True, exist_ok=True)
    efi_dir.mkdir(parents=True, exist_ok=True)

    # Limine configuration
    shutil.copy2(PROJECT_ROOT / "etc" / "limine.conf", boot_dir / "limine.conf")

    # Limine bootloader files
    for fname in ["limine-bios.sys", "limine-bios-cd.bin", "limine-uefi-cd.bin"]:
        src = limine_binary(fname)
        if not src.is_file():
            error(f"Missing Limine file: {src}")
        shutil.copy2(src, boot_dir)

    # EFI executable
    efi_src = limine_binary("BOOTX64.EFI")
    if not efi_src.is_file():
        error(f"Missing Limine EFI file: {efi_src}")
    shutil.copy2(efi_src, efi_dir)

    # Kernel binary
    shutil.copy2(kernel_bin, iso_root / "boot" / KERNEL_NAME)

    finished("ISO filesystem")


def build_iso(profile_name: str):
    """Create the bootable ISO image with xorriso and limine-deploy."""
    iso_root = TARGET / "x86_64-unknown-none" / profile_name / "iso-root"
    iso_name = TARGET / "x86_64-unknown-none" / profile_name / "image.iso"

    status("Compiling", "ISO image")
    run([
        "xorriso", "-as", "mkisofs",
        "-R", "-r", "-J", "-quiet",
        "-b", "boot/limine/limine-bios-cd.bin",
        "-no-emul-boot", "-boot-load-size", "4", "-boot-info-table",
        "-hfsplus", "-apm-block-size", "2048",
        "--efi-boot", "boot/limine/limine-uefi-cd.bin",
        "-efi-boot-part", "--efi-boot-image",
        str(iso_root),
        "-o", str(iso_name),
    ], stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL)

    # Deploy Limine
    run([str(limine_binary("limine")), "bios-install", str(iso_name)], stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL)
    finished("ISO image")


def iso_needs_rebuild(profile_name: str) -> bool:
    """
    Return True if the ISO must be rebuilt, i.e. it doesn't exist or
    any of its inputs are newer.
    """
    iso = TARGET / "x86_64-unknown-none" / profile_name / "image.iso"
    sources = [
        TARGET / "x86_64-unknown-none" / profile_name / KERNEL_NAME,
        PROJECT_ROOT / "etc" / "limine.conf",
        limine_binary("limine-bios.sys"),
        limine_binary("limine-bios-cd.bin"),
        limine_binary("limine-uefi-cd.bin"),
        limine_binary("BOOTX64.EFI"),
        limine_binary("limine"),            # the deployment tool itself
        limine_version_file(),              # version change triggers a rebuild
    ]
    return not is_up_to_date(iso, *sources)


# ----------------------------------------------------------------------
# QEMU runner
# ----------------------------------------------------------------------
def run_qemu(profile_name: str):
    """Boot the ISO in QEMU."""
    iso_name = TARGET / "x86_64-unknown-none" / profile_name / "image.iso"
    if not iso_name.is_file():
        error(f"ISO not found: {iso_name}")

    kvm = os.access("/dev/kvm", os.W_OK)
    if kvm:
        status("Available", "KVM")

    finished("guest startup")

    print("-"*SEP)

    qemu_cmd = [
        "qemu-system-x86_64",
        "-device",
        "isa-debug-exit,iobase=0x501,iosize=0x01",
        "-no-reboot",
        "-cdrom", str(iso_name),
        "-boot", "d",
        *( [ "--enable-kvm" ] if kvm else []),
        "-cpu", "host",
        "-m", "2G",
        "-smp", "2",
        "-serial", "stdio",
        "-vga", "std",
        "-machine", "q35,accel=kvm:tcg",
        "-device", "ahci,id=ahci",
        "-rtc", "base=utc",
        # "-nographic",
    ]
    subprocess.run(qemu_cmd)
    print("\b"+"-"*SEP)


# ----------------------------------------------------------------------
# Top‑level commands
# ----------------------------------------------------------------------
def cmd_clear():
    """Remove build artifacts (cargo clean)."""
    run(["cargo", "clean"])


def cmd_build(profiles: dict):
    """Build kernel and ISO, skipping steps when possible."""
    ensure_cargo_toml()
    prepare_limine()

    profile_name = read_current_profile()
    profile = profiles[profile_name]
    build_kernel(profile)

    if iso_needs_rebuild(profile_name):
        setup_iso(profile_name)
        build_iso(profile_name)
    else:
        finished("ISO image (up‑to‑date)")


def cmd_run(profiles: dict):
    """Build everything and launch QEMU."""
    cmd_build(profiles)
    profile_name = read_current_profile()
    run_qemu(profile_name)


def cmd_config(profiles: dict, args):
    """Select a build profile and regenerate Cargo.toml."""
    profile_name = args.profile
    if profile_name is None:
        profile_name = "dev"
        warn(f"no profile specified. selecting `{BOLD}{profile_name}{NC}` by default.")
    if profile_name not in profiles:
        error(f"profile `{BOLD}{profile_name}{NC}` does not exist.")

    write_current_profile(profile_name)
    generate_cargo_toml(profile_name)


# ----------------------------------------------------------------------
# Main
# ----------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description="Build and test pipeline for the kernel."
    )
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("clear", help="Remove build artifacts (cargo clean)")
    sub.add_parser("build", help="Build kernel and ISO (incremental)")
    sub.add_parser("run",   help="Build ISO and launch QEMU")

    config_parser = sub.add_parser("config", help="Select build profile")
    config_parser.add_argument(
        "profile", nargs="?", default=None,
        help="Profile name (default: dev). See etc/profiles/*.toml"
    )

    args = parser.parse_args()

    # Always check required tools before doing anything
    check_tools()

    profiles = load_profiles()

    if args.command == "clear":
        cmd_clear()
    elif args.command == "build":
        cmd_build(profiles)
    elif args.command == "run":
        cmd_run(profiles)
    elif args.command == "config":
        cmd_config(profiles, args)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
