[package]
name = "{KERNEL_NAME}"
version = "0.4.1-56.21"
edition = "2024"

[dependencies]
acpi = {{ version = "6", features = ["alloc"] }}
bitflags = "2"
extrum = {{ version = "0.1.3", features = ["no_std"] }}
heapless = "0"
lazy_static = {{ version = "1", features = ["spin_no_std"] }}
limine = "0"
x86 = "0"

[profile.dev]
panic = "abort"

[profile.release]
panic = "abort"

[profile.dbg]
inherits = "dev"

[features]
lowlog = []
devlog = []
